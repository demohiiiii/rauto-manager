# Database
# If you use sslmode=require with hosted Postgres, prefer also adding
# uselibpqcompat=true to avoid future pg semantic changes warnings.
# If your provider offers a separate direct connection string for migrations
# (for example Neon), set DIRECT_DATABASE_URL to that value.
DATABASE_URL="postgresql://user:password@localhost:5432/rauto_manager"
# DIRECT_DATABASE_URL="postgresql://user:password@host:5432/rauto_manager"

# Agent Configuration
AGENT_HEARTBEAT_INTERVAL=30000
AGENT_TIMEOUT=120000
AGENT_API_KEY="your-agent-api-key-change-in-production"
NEXT_PUBLIC_AGENT_API_KEY="your-agent-api-key-change-in-production"
# Optional override for the UI-generated `rauto agent` command.
# Defaults to the current browser origin when omitted.
# NEXT_PUBLIC_MANAGER_URL="https://manager.example.com"
# Optional override for the UI-generated gRPC agent command.
# Defaults to the current browser host on port 50051 when omitted.
# NEXT_PUBLIC_MANAGER_GRPC_URL="http://manager.example.com:50051"

# Optional gRPC reporting service. Disabled by default; enable only when you
# explicitly want manager-side gRPC reporting in addition to HTTP routes.
# MANAGER_GRPC_ENABLED="true"
# MANAGER_GRPC_HOST="0.0.0.0"
# MANAGER_GRPC_PORT="50051"

# Authentication
JWT_SECRET="your-jwt-secret-key-change-in-production"
